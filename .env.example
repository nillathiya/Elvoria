# ============================================================
#  Copy to .env.local and fill in. Never commit the real file.
#  Spec §21: RPC URLs and API keys come from the environment, never source.
# ============================================================

# --- Secrets -------------------------------------------------

# REQUIRED IN PRODUCTION. A long random string (e.g. `openssl rand -hex 32`).
# PINs and passwords are HMAC'd with this before scrypt, so a stolen storage/
# directory cannot be brute-forced offline. This matters most for the 6-digit
# PINs: only 1,000,000 combinations, which is hours of offline guessing without
# a pepper and impossible with one.
# WARNING: changing this invalidates every existing PIN and password.
AUTH_PEPPER=

# --- Storage -------------------------------------------------

# Where the JSON files live. Defaults to ./storage. Point this at a persistent
# volume in production — a container filesystem loses every deposit record on
# redeploy. Must be a real disk: atomic rename and O_EXCL locking are not
# reliable on NFS or most network shares.
# STORAGE_DIR=/var/lib/elvoria/storage

# --- Networking ----------------------------------------------

# Set to 1 ONLY when a trusted reverse proxy (nginx, Cloudflare) sets
# X-Forwarded-For. When set, the first value in that header is trusted as the
# client IP.
# Do NOT set this if the app is directly internet-facing: a client could then
# spoof the header and sidestep login lockout entirely.
#
# IMPORTANT: login lockout is scoped per client IP. Next.js does not expose the
# socket address to route handlers, so with no proxy header the app cannot tell
# clients apart and every anonymous request shares one lockout bucket — meaning
# any attacker can lock the real admin out with 5 wrong PINs. Put this app
# behind a proxy that sets X-Real-IP or X-Forwarded-For.
# TRUST_PROXY=1

# --- Blockchain RPC (Phase 6) --------------------------------
# Verification reads the chain directly; no private keys are needed or used.

# BSC_RPC_URL=https://bsc-dataseed.binance.org
# ETH_RPC_URL=https://ethereum-rpc.publicnode.com
# TRON_API_URL=https://api.trongrid.io
# TRON_API_KEY=
# BTC_API_URL=https://blockstream.info/api
